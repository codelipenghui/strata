            "last",
            "max",
            "mean"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "description": "live files this controller owns (sharding load); per-namespace: Strata \u2014 Namespace dashboard"
    },
