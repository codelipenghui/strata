{
  "uid": "strata-controller",
  "title": "Strata \u2014 Controller Node",
  "tags": [
    "strata"
  ],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(strata_controller_is_leader, instance)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "sort": 1,
        "label": "instance"
      }
    ]
  },
  "links": [
    {
      "type": "dashboards",
      "title": "Strata dashboards",
      "asDropdown": true,
      "keepTime": true,
      "includeVars": true,
      "tags": [
        "strata"
      ],
      "icon": "external link"
    }
  ],
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Controller \u2014 $instance",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Leader (controller latch)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "expr": "max(strata_controller_is_leader{instance=~\"$instance\"})",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "no",
                  "color": "red",
                  "index": 0
                },
                "1": {
                  "text": "yes",
                  "color": "green",
                  "index": 1
                }
              }
            }
          ],
          "color": {
            "mode": "fixed",
            "fixedColor": "text"
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "description": "1 if this instance holds the global cluster-controller latch"
    },
    {
      "id": 3,
      "type": "stat",
      "title": "ZK connected",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 1
      },
      "targets": [
        {
          "expr": "min(strata_controller_zk_connected{instance=~\"$instance\"})",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "no",
                  "color": "red",
                  "index": 0
                },
                "1": {
                  "text": "yes",
                  "color": "green",
                  "index": 1
                }
              }
            }
          ],
          "color": {
            "mode": "fixed",
            "fixedColor": "text"
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Backend",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 1
      },
      "targets": [
        {
          "expr": "max(strata_controller_namespace_log_active{instance=~\"$instance\"})",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "zk",
                  "color": "blue",
                  "index": 0
                },
                "1": {
                  "text": "namespace-log",
                  "color": "green",
                  "index": 1
                }
              }
            }
          ],
          "color": {
            "mode": "fixed",
            "fixedColor": "text"
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Sharding",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 1
      },
      "targets": [
        {
          "expr": "max(strata_controller_sharding_active{instance=~\"$instance\"})",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "single-leader",
                  "color": "blue",
                  "index": 0
                },
                "1": {
                  "text": "sharded",
                  "color": "green",
                  "index": 1
                }
              }
            }
          ],
          "color": {
            "mode": "fixed",
            "fixedColor": "text"
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Namespaces owned",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 1
      },
      "targets": [
        {
          "expr": "sum(strata_controller_namespaces_loaded{instance=~\"$instance\"})",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "description": "live namespace repos on this controller"
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Controllers",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 1
      },
      "targets": [
        {
          "expr": "max(strata_controller_endpoints_configured{instance=~\"$instance\"})",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "description": "configured controller membership"
    },
    {
      "id": 8,
      "type": "row",
      "title": "Controller requests (SCP)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "collapsed": false
    },
    {
      "id": 81,
      "type": "timeseries",
      "title": "Controller request rate by opcode",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "targets": [
        {
          "expr": "sum by (opcode)(rate(strata_scp_request_duration_seconds_count{instance=~\"$instance\",opcode=~\"CREATE_FILE|CREATE_CHUNK|ALLOCATE_WRITER_EPOCH|SEAL_CHUNK_META|ABORT_CHUNK_META|SEAL_FILE|LOOKUP_FILE|LOOKUP_PATH|DELETE_FILES|REGISTER_NODE|NODE_HEARTBEAT\"}[$__rate_interval]))",
          "refId": "A",
          "legendFormat": "{{opcode}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "last",
            "max",
            "mean"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "description": "controller SCP request rate by opcode for this controller (excludes data-plane ops + PING)"
    },
    {
      "id": 82,
      "type": "timeseries",
      "title": "Controller request p99 latency by opcode",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le,opcode)(rate(strata_scp_request_duration_seconds_bucket{instance=~\"$instance\",opcode=~\"CREATE_FILE|CREATE_CHUNK|ALLOCATE_WRITER_EPOCH|SEAL_CHUNK_META|ABORT_CHUNK_META|SEAL_FILE|LOOKUP_FILE|LOOKUP_PATH|DELETE_FILES|REGISTER_NODE|NODE_HEARTBEAT\"}[$__rate_interval])))",
          "refId": "A",
          "legendFormat": "{{opcode}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "last",
            "max",
            "mean"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "description": "p99 controller request latency by opcode (incl. async waits)"
    },
    {
      "id": 10,
      "type": "row",
      "title": "Namespaces owned by this controller",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "collapsed": false
    },
