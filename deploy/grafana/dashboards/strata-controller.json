        }
      },
      "description": "open metadata-log bytes this controller owns; per-namespace: Strata \u2014 Namespace dashboard"
    },
    {
      "id": 20,
      "type": "row",
      "title": "Metadata-log activity",
      "gridPos": {
        "h": 1,
