      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "zk",
                  "color": "blue",
                  "index": 0
                },
                "1": {
                  "text": "namespace-log",
                  "color": "green",
                  "index": 1
                }
              }
            }
          ],
          "color": {
            "mode": "fixed",
            "fixedColor": "text"
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "description": "zk = shared store; namespace-log = per-namespace strata-file logs"
    },
