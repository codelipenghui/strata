{
  "uid": "strata-overview",
  "title": "Strata — Cluster",
  "tags": ["strata"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "links": [
    {
      "type": "dashboards",
      "title": "Strata dashboards",
      "asDropdown": true,
      "keepTime": true,
      "includeVars": true,
      "tags": ["strata"],
      "icon": "external link"
    }
  ],
  "panels": [

    {
      "id": 1,
      "type": "row",
      "title": "Health & SLOs",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Chunks unavailable",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "targets": [
        { "expr": "sum(strata_chunks_unavailable)", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Under-replicated",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "targets": [
        { "expr": "sum(strata_chunks_under_replicated)", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },

    {
      "id": 4,
      "type": "stat",
      "title": "At min redundancy",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "targets": [
        { "expr": "sum(strata_chunks_at_min_redundancy)", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },

    {
      "id": 5,
      "type": "stat",
      "title": "Metadata leaders (want 1)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "targets": [
        { "expr": "sum(strata_meta_is_leader)", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },

    {
      "id": 6,
      "type": "stat",
      "title": "ZK connected (min)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "targets": [
        { "expr": "min(strata_meta_zk_connected)", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },

    {
      "id": 7,
      "type": "stat",
      "title": "Nodes alive",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "targets": [
        { "expr": "sum(strata_nodes{state=\"alive\"})", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },

    {
      "id": 8,
      "type": "stat",
      "title": "Nodes suspect/dead",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 5 },
      "targets": [
        { "expr": "sum(strata_nodes{state=~\"suspect|dead\"})", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },

    {
      "id": 9,
      "type": "stat",
      "title": "Write throughput",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 5 },
      "targets": [
        { "expr": "sum(rate(strata_node_append_bytes_total[$__rate_interval]))", "refId": "A", "instant": false }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },

    {
      "id": 10,
      "type": "stat",
      "title": "Read throughput",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 5 },
      "targets": [
        { "expr": "sum(rate(strata_node_read_bytes_total[$__rate_interval]))", "refId": "A", "instant": false }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },

    {
      "id": 11,
      "type": "stat",
      "title": "Request rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 5 },
      "targets": [
        { "expr": "sum(rate(strata_scp_request_duration_seconds_count[$__rate_interval]))", "refId": "A", "instant": false }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },

    {
      "id": 12,
      "type": "stat",
      "title": "Error ratio",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 5 },
      "targets": [
        {
          "expr": "sum(rate(strata_scp_request_duration_seconds_count{status=\"error\"}[$__rate_interval])) / clamp_min(sum(rate(strata_scp_request_duration_seconds_count[$__rate_interval])), 1)",
          "refId": "A",
          "instant": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.01 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },

    {
      "id": 20,
      "type": "row",
      "title": "Durability & repair",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false
    },

    {
      "id": 21,
      "type": "timeseries",
      "title": "Chunk durability census",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "targets": [
        { "expr": "sum(strata_chunks_unavailable)", "refId": "A", "legendFormat": "unavailable" },
        { "expr": "sum(strata_chunks_under_replicated)", "refId": "B", "legendFormat": "under-replicated" },
        { "expr": "sum(strata_chunks_at_min_redundancy)", "refId": "C", "legendFormat": "at min redundancy" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 10, "showPoints": "never" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max", "mean"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },

    {
      "id": 22,
      "type": "timeseries",
      "title": "Repair backlog & in-flight",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "targets": [
        { "expr": "sum(strata_repair_backlog)", "refId": "A", "legendFormat": "backlog (chunks)" },
        { "expr": "sum(strata_repair_inflight)", "refId": "B", "legendFormat": "in-flight commands" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 10, "showPoints": "never" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max", "mean"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },

    {
      "id": 30,
      "type": "row",
      "title": "Cluster membership",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false
    },

    {
      "id": 31,
      "type": "timeseries",
      "title": "Storage nodes by liveness",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "targets": [
        { "expr": "sum by (state)(strata_nodes)", "refId": "A", "legendFormat": "{{state}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 30,
            "showPoints": "never",
            "stacking": { "mode": "normal", "group": "A" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "alive" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "suspect" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "dead" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max", "mean"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },

    {
      "id": 32,
      "type": "table",
      "title": "Per-node fleet",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 27 },
      "targets": [
        { "expr": "strata_node_registered", "refId": "A", "instant": true, "format": "table" },
        { "expr": "strata_node_capacity_used_ratio", "refId": "B", "instant": true, "format": "table" },
        { "expr": "strata_node_disk_used_bytes", "refId": "C", "instant": true, "format": "table" },
        { "expr": "strata_node_capacity_bytes", "refId": "D", "instant": true, "format": "table" },
        { "expr": "strata_node_chunks{state=\"open\"}", "refId": "E", "instant": true, "format": "table" },
        { "expr": "strata_node_chunks{state=\"sealed\"}", "refId": "F", "instant": true, "format": "table" }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "job": true,
              "role": true,
              "__name__": true,
              "state": true
            },
            "renameByName": {
              "instance": "Node",
              "Value #A": "Registered",
              "Value #B": "Capacity %",
              "Value #C": "Disk used",
              "Value #D": "Capacity",
              "Value #E": "Open chunks",
              "Value #F": "Sealed chunks"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "links": [
            {
              "title": "Open node dashboard",
              "url": "/d/strata-node?var-node=${__data.fields.Node}&${__url_time_range}"
            }
          ]
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Capacity %" },
            "properties": [
              { "id": "unit", "value": "percentunit" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 0.8 },
                    { "color": "red", "value": 0.9 }
                  ]
                }
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Disk used" },
            "properties": [
              { "id": "unit", "value": "bytes" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Capacity" },
            "properties": [
              { "id": "unit", "value": "bytes" }
            ]
          }
        ]
      }
    },

    {
      "id": 40,
      "type": "row",
      "title": "Capacity",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 37 },
      "collapsed": false
    },

    {
      "id": 41,
      "type": "timeseries",
      "title": "Capacity used ratio by node",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 38 },
      "targets": [
        { "expr": "strata_node_capacity_used_ratio", "refId": "A", "legendFormat": "{{instance}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "fillOpacity": 10,
            "showPoints": "never",
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "red", "value": 0.9 }
            ]
          },
          "links": [
            {
              "title": "Open node dashboard",
              "url": "/d/strata-node?var-node=${__field.labels.instance}&${__url_time_range}"
            }
          ]
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max", "mean"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },

    {
      "id": 42,
      "type": "timeseries",
      "title": "Disk used vs total capacity",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 38 },
      "targets": [
        { "expr": "sum(strata_node_disk_used_bytes)", "refId": "A", "legendFormat": "used" },
        { "expr": "sum(strata_node_capacity_bytes)", "refId": "B", "legendFormat": "capacity" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "fillOpacity": 10, "showPoints": "never" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max", "mean"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },

    {
      "id": 50,
      "type": "row",
      "title": "I/O throughput",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 46 },
      "collapsed": false
    },

    {
      "id": 51,
      "type": "timeseries",
      "title": "Read vs write throughput",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 47 },
      "targets": [
        { "expr": "sum(rate(strata_node_append_bytes_total[$__rate_interval]))", "refId": "A", "legendFormat": "write" },
        { "expr": "sum(rate(strata_node_read_bytes_total[$__rate_interval]))", "refId": "B", "legendFormat": "read" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "fillOpacity": 10, "showPoints": "never" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max", "mean"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },

    {
      "id": 52,
      "type": "timeseries",
      "title": "Write & read ops/s",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 47 },
      "targets": [
        { "expr": "sum(rate(strata_node_append_ops_total[$__rate_interval]))", "refId": "A", "legendFormat": "append ops" },
        { "expr": "sum(rate(strata_node_read_ops_total[$__rate_interval]))", "refId": "B", "legendFormat": "read ops" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 10, "showPoints": "never" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max", "mean"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },

    {
      "id": 53,
      "type": "timeseries",
      "title": "Group-commit force/s (fsync) by node",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 55 },
      "targets": [
        { "expr": "sum by (instance)(rate(strata_node_groupcommit_force_total[$__rate_interval]))", "refId": "A", "legendFormat": "{{instance}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 10, "showPoints": "never" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max", "mean"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },

    {
      "id": 54,
      "type": "timeseries",
      "title": "Avg bytes per append",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 55 },
      "targets": [
        {
          "expr": "sum(rate(strata_node_append_bytes_total[$__rate_interval])) / clamp_min(sum(rate(strata_node_append_ops_total[$__rate_interval])), 1)",
          "refId": "A",
          "legendFormat": "bytes/append"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "fillOpacity": 10, "showPoints": "never" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max", "mean"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },

    {
      "id": 60,
      "type": "row",
      "title": "Requests (RED)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 63 },
      "collapsed": false
    },

    {
      "id": 61,
      "type": "timeseries",
      "title": "Request rate by opcode",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 64 },
      "targets": [
        { "expr": "sum by (opcode)(rate(strata_scp_request_duration_seconds_count[$__rate_interval]))", "refId": "A", "legendFormat": "{{opcode}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "fillOpacity": 10, "showPoints": "never" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max", "mean"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },

    {
      "id": 62,
      "type": "timeseries",
      "title": "Error rate by opcode",
