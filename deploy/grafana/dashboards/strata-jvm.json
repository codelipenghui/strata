{
  "uid": "strata-jvm",
  "title": "Strata — JVM & Runtime",
  "tags": ["strata"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "links": [
    {
      "type": "dashboards",
      "title": "Strata dashboards",
      "asDropdown": true,
      "keepTime": true,
      "includeVars": true,
      "tags": ["strata"],
      "icon": "external link"
    }
  ],
  "templating": { "list": [
    {
      "name": "node",
      "label": "Node",
      "type": "query",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "query": { "query": "label_values(strata_node_disk_used_bytes, instance)", "refId": "StandardVariableQuery" },
      "includeAll": true,
      "multi": true,
      "allValue": ".*",
      "current": { "text": "All", "value": "$__all" },
      "refresh": 2,
      "sort": 1
    }
  ] },
  "panels": [

    {
      "id": 1,
      "type": "row",
      "title": "Runtime overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Uptime (min)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "targets": [
        { "expr": "min(process_uptime_seconds{instance=~\"$node\"})", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Heap used %",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "targets": [
        {
          "expr": "max(sum by (instance)(jvm_memory_used_bytes{area=\"heap\",instance=~\"$node\"}) / sum by (instance)(jvm_memory_max_bytes{area=\"heap\",instance=~\"$node\"}))",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Live threads",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "targets": [
        { "expr": "sum(jvm_threads_live_threads{instance=~\"$node\"})", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },

    {
      "id": 5,
      "type": "stat",
      "title": "Process CPU",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "targets": [
        { "expr": "max(process_cpu_usage{instance=~\"$node\"})", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },

    {
      "id": 6,
      "type": "stat",
      "title": "System load (1m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "targets": [
        { "expr": "max(system_load_average_1m{instance=~\"$node\"})", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },

    {
      "id": 7,
      "type": "stat",
      "title": "Open file descriptors",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "targets": [
        { "expr": "max(process_files_open_files{instance=~\"$node\"})", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },

    {
      "id": 8,
      "type": "stat",
      "title": "GC time/s",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 5 },
      "targets": [
        { "expr": "sum(rate(jvm_gc_pause_seconds_sum{instance=~\"$node\"}[$__rate_interval]))", "refId": "A", "instant": false }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },

    {
      "id": 10,
      "type": "row",
      "title": "Memory",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false
    },

    {
      "id": 11,
      "type": "timeseries",
      "title": "Heap used by node",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "targets": [
        { "expr": "sum by (instance)(jvm_memory_used_bytes{area=\"heap\",instance=~\"$node\"})", "refId": "A", "legendFormat": "{{instance}} used" },
        { "expr": "sum by (instance)(jvm_memory_max_bytes{area=\"heap\",instance=~\"$node\"})", "refId": "B", "legendFormat": "{{instance}} max" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "fillOpacity": 10, "showPoints": "never" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max", "mean"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },

    {
      "id": 12,
      "type": "timeseries",
      "title": "Heap used % by node",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "targets": [
        {
          "expr": "sum by (instance)(jvm_memory_used_bytes{area=\"heap\",instance=~\"$node\"}) / sum by (instance)(jvm_memory_max_bytes{area=\"heap\",instance=~\"$node\"})",
          "refId": "A",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "fillOpacity": 10, "showPoints": "never" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max", "mean"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },

    {
      "id": 13,
      "type": "timeseries",
      "title": "Non-heap used by node",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "targets": [
        { "expr": "sum by (instance)(jvm_memory_used_bytes{area=\"nonheap\",instance=~\"$node\"})", "refId": "A", "legendFormat": "{{instance}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "fillOpacity": 10, "showPoints": "never" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max", "mean"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },

    {
      "id": 14,
      "type": "timeseries",
      "title": "Memory pools",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "targets": [
        { "expr": "sum by (id)(jvm_memory_used_bytes{instance=~\"$node\"})", "refId": "A", "legendFormat": "{{id}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "fillOpacity": 10, "showPoints": "never" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max", "mean"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },

    {
      "id": 15,
      "type": "timeseries",
      "title": "Heap committed / used / max",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "targets": [
        { "expr": "sum(jvm_memory_committed_bytes{area=\"heap\",instance=~\"$node\"})", "refId": "A", "legendFormat": "committed" },
        { "expr": "sum(jvm_memory_used_bytes{area=\"heap\",instance=~\"$node\"})", "refId": "B", "legendFormat": "used" },
        { "expr": "sum(jvm_memory_max_bytes{area=\"heap\",instance=~\"$node\"})", "refId": "C", "legendFormat": "max" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "fillOpacity": 10, "showPoints": "never" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max", "mean"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },

    {
      "id": 20,
      "type": "row",
      "title": "Garbage collection",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 },
      "collapsed": false
    },

    {
      "id": 21,
      "type": "timeseries",
      "title": "GC time/s by node",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 35 },
      "targets": [
        { "expr": "sum by (instance)(rate(jvm_gc_pause_seconds_sum{instance=~\"$node\"}[$__rate_interval]))", "refId": "A", "legendFormat": "{{instance}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "fillOpacity": 10, "showPoints": "never" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max", "mean"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },

    {
      "id": 22,
      "type": "timeseries",
      "title": "GC count/s by action",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 35 },
      "targets": [
        { "expr": "sum by (action)(rate(jvm_gc_pause_seconds_count{instance=~\"$node\"}[$__rate_interval]))", "refId": "A", "legendFormat": "{{action}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 10, "showPoints": "never" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max", "mean"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },

    {
      "id": 23,
      "type": "timeseries",
      "title": "Avg GC pause by action",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 43 },
      "targets": [
        {
          "expr": "sum by (action)(rate(jvm_gc_pause_seconds_sum{instance=~\"$node\"}[$__rate_interval])) / clamp_min(sum by (action)(rate(jvm_gc_pause_seconds_count{instance=~\"$node\"}[$__rate_interval])), 1)",
          "refId": "A",
          "legendFormat": "{{action}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "fillOpacity": 10, "showPoints": "never" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max", "mean"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },

    {
      "id": 24,
      "type": "timeseries",
      "title": "Allocation rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 43 },
      "targets": [
        { "expr": "sum(rate(jvm_gc_memory_allocated_bytes_total{instance=~\"$node\"}[$__rate_interval]))", "refId": "A", "legendFormat": "allocated" }
