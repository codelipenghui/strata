      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 51 },
      "targets": [
        { "expr": "sum(rate(jvm_gc_memory_promoted_bytes_total{instance=~\"$node\"}[$__rate_interval]))", "refId": "A", "legendFormat": "promoted" }
