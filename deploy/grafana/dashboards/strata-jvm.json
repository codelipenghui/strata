    },

    {
      "id": 42,
      "type": "timeseries",
      "title": "System load (1m) + CPU count",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 69 },
