{
  "uid": "strata-overview",
  "title": "Strata — Cluster Overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Chunks unavailable (data-loss exposure)",
      "gridPos": { "h": 4, "w": 5, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "sum(strata_chunks_unavailable)", "refId": "A" } ],
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }, "color": { "mode": "thresholds" } } }
    },
    {
      "id": 2, "type": "stat", "title": "Chunks under-replicated",
      "gridPos": { "h": 4, "w": 5, "x": 5, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "sum(strata_chunks_under_replicated)", "refId": "A" } ],
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1 } ] }, "color": { "mode": "thresholds" } } }
    },
    {
      "id": 3, "type": "stat", "title": "Chunks at min redundancy (1 replica)",
      "gridPos": { "h": 4, "w": 6, "x": 10, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "sum(strata_chunks_at_min_redundancy)", "refId": "A" } ],
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1 } ] }, "color": { "mode": "thresholds" } } }
    },
    {
      "id": 4, "type": "stat", "title": "Metadata leaders (want 1)",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "sum(strata_meta_is_leader)", "refId": "A" } ]
    },
    {
      "id": 5, "type": "stat", "title": "ZK connected (min)",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "min(strata_meta_zk_connected)", "refId": "A" } ],
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }, "color": { "mode": "thresholds" } } }
    },
    {
      "id": 6, "type": "timeseries", "title": "Storage nodes by liveness",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "sum by (state) (strata_nodes)", "refId": "A", "legendFormat": "{{state}}" } ]
    },
    {
      "id": 7, "type": "timeseries", "title": "Repair backlog & in-flight",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(strata_repair_backlog)", "refId": "A", "legendFormat": "backlog (chunks)" },
        { "expr": "sum(strata_repair_inflight)", "refId": "B", "legendFormat": "in-flight commands" }
      ]
    },
    {
      "id": 8, "type": "timeseries", "title": "Capacity used ratio (by node)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "strata_node_capacity_used_ratio", "refId": "A", "legendFormat": "{{instance}}" } ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } }
    },
    {
      "id": 9, "type": "timeseries", "title": "Local chunks by state (by node)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "sum by (instance, state) (strata_node_chunks)", "refId": "A", "legendFormat": "{{instance}} {{state}}" } ]
    },
    {
      "id": 10, "type": "timeseries", "title": "Write throughput",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "sum(rate(strata_node_append_bytes_total[1m]))", "refId": "A", "legendFormat": "append bytes/s" } ],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    },
    {
      "id": 11, "type": "timeseries", "title": "Write ops/s",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "sum(rate(strata_node_append_ops_total[1m]))", "refId": "A", "legendFormat": "appends/s" } ]
    },
    {
      "id": 12, "type": "timeseries", "title": "Group-commit force/s (fsync rate)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "sum by (instance) (rate(strata_node_groupcommit_force_total[1m]))", "refId": "A", "legendFormat": "{{instance}}" } ]
    },
    {
      "id": 13, "type": "timeseries", "title": "JVM heap used (by instance)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "sum by (instance) (jvm_memory_used_bytes{area=\"heap\"})", "refId": "A", "legendFormat": "{{instance}}" } ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 14, "type": "timeseries", "title": "GC pause rate (by instance)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "sum by (instance) (rate(jvm_gc_pause_seconds_sum[1m]))", "refId": "A", "legendFormat": "{{instance}}" } ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ]
}
