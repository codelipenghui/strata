    {
      "id": 21,
      "type": "timeseries",
      "title": "Request rate by top-level znode",
      "description": "ZK request rate (ops/s) attributed to the top-level znode (key label): strata = Strata's metadata plane (/strata/...), zookeeper = ZK internal housekeeping. ZK keys this counter on the first path segment, so a single-rooted app shows one bucket — for per-operation detail use strata_scp_request_duration{opcode} on the Cluster/Node dashboards.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 44
      },
      "targets": [
        {
          "expr": "rate(write_per_namespace_count{instance=~\"$instance\"}[$__rate_interval])",
          "refId": "A",
          "legendFormat": "{{key}} write"
        },
        {
          "expr": "rate(read_per_namespace_count{instance=~\"$instance\"}[$__rate_interval])",
          "refId": "B",
          "legendFormat": "{{key}} read"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "last",
            "max",
            "mean"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Throughput by top-level znode",
      "description": "ZK request throughput (bytes/s) attributed to the top-level znode (key label): strata = Strata's metadata plane, zookeeper = ZK internal. Coarse by design (keyed on the first path segment); for per-operation detail use Strata's own metadata metrics.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 44
      },
      "targets": [
        {
          "expr": "rate(write_per_namespace_sum{instance=~\"$instance\"}[$__rate_interval])",
          "refId": "A",
          "legendFormat": "{{key}} write"
        },
        {
          "expr": "rate(read_per_namespace_sum{instance=~\"$instance\"}[$__rate_interval])",
          "refId": "B",
          "legendFormat": "{{key}} read"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
