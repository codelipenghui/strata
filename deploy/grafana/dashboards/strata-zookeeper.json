{
  "uid": "strata-zookeeper",
  "title": "Strata — ZooKeeper",
  "description": "ZooKeeper (metadata store) health. Metrics from ZooKeeper's built-in Prometheus provider (zoo.cfg metricsProvider). Panel/metric selection adapted from the community dashboard \"ZooKeeper by Prometheus\" (grafana.com/grafana/dashboards/10465), rebuilt in Strata's dashboard style. The 'ZK request load' row attributes request rate/throughput to the top-level znode (key label): strata = Strata's metadata plane vs zookeeper = ZK internal housekeeping.",
  "tags": [
    "strata",
    "zookeeper"
  ],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "links": [
    {
      "type": "dashboards",
      "title": "Strata dashboards",
      "asDropdown": true,
      "keepTime": true,
      "includeVars": true,
      "tags": [
        "strata"
      ],
      "icon": "external link"
    }
  ],
  "templating": {
    "list": [
      {
        "name": "instance",
        "label": "ZK instance",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "query": "label_values(znode_count, instance)",
          "refId": "StandardVariableQuery"
        },
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Overview",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Alive connections",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "expr": "sum(num_alive_connections{instance=~\"$instance\"})",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 3,
